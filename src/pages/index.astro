---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Story from "../components/Story.astro";
import Faq from "../components/Faq.astro";
import Travel from "../components/Travel.astro";
import Party from "../components/Party.astro";
import Registry from "../components/Registry.astro";
import Gallery from "../components/Gallery.astro";
import Rsvp from "../components/Rsvp.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Alyssa & Nathan — August 8, 2026"
  description="Alyssa & Nathan are getting married on August 8, 2026 at Stone Valley Estates in Huntingdon, PA. Join us for our story, FAQ, travel info, gallery, and RSVP."
>
  <Header />
  <main id="main">
    <Hero />
    <Story />
    <Faq />
    <Travel />
    <Party />
    <Registry />
    <Gallery />
    <Rsvp />
  </main>
  <Footer />
</Layout>
