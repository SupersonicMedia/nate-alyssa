---
const ladies = [
  {
    name: "Mackenzie Dasher",
    role: "Maid of Honor",
    bio: "My absolute best friend. She knows me better than I know myself, and I have no idea where I would be today without her.",
    initials: "MD",
  },
  {
    name: "Kelsey Foor",
    role: "Bridesmaid",
    bio: "My sister-in-law who I love with all my heart. I seriously lucked out. She became my sister through marriage, but truly feels like my sister by heart.",
    initials: "KF",
  },
  {
    name: "Morgan Karpinski",
    role: "Bridesmaid",
    bio: "From the start, I knew she was special and I am so lucky to have her in my life as my soon-to-be sister-in-law who already feels like family. I adore her and can't wait to officially call her my sister.",
    initials: "MK",
  },
];

const gents = [
  {
    name: "Ben Karpinski",
    role: "Best Man",
    bio: "My brother-in-law. He has taught me that I don't know much. I look up to him in more ways than I can count. I hope to be as good of a husband and father as Ben is.",
    initials: "BK",
  },
  {
    name: "Kyle Foor",
    role: "Groomsman",
    bio: "My soon to be brother-in-law. Kyle has always been so welcoming to me and I love the time we get to spend together. He truly is the older brother I never had before.",
    initials: "KF",
  },
  {
    name: "Jacob Dasher",
    role: "Groomsman",
    bio: "My good buddy Jake. We aren't childhood friends but it feels like I have known you my whole life. We've had a lot of great times together and I hope we have many more.",
    initials: "JD",
  },
];
---

<section id="party" class="section party">
  <div class="container-wide">
    <header class="party__header reveal">
      <p class="eyebrow">Bridal Party</p>
      <h2 class="party__title">The people we love</h2>
      <p class="party__lede">
        Standing by our side on the big day — the friends and family who have shaped our lives
        and our love story.
      </p>
    </header>

    <div class="party__group reveal">
      <h3 class="party__group-title script">Meet the Ladies</h3>
      <div class="party__grid">
        {ladies.map((p) => (
          <article class="party__card">
            <div class="party__avatar" aria-hidden="true">{p.initials}</div>
            <h4 class="party__name">{p.name}</h4>
            <p class="party__role">{p.role}</p>
            <p class="party__bio">{p.bio}</p>
          </article>
        ))}
      </div>
    </div>

    <div class="party__group reveal">
      <h3 class="party__group-title script">Meet the Gents</h3>
      <div class="party__grid">
        {gents.map((p) => (
          <article class="party__card">
            <div class="party__avatar party__avatar--gent" aria-hidden="true">{p.initials}</div>
            <h4 class="party__name">{p.name}</h4>
            <p class="party__role">{p.role}</p>
            <p class="party__bio">{p.bio}</p>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .party {
    background: var(--color-cream-50);
    border-block: 1px solid color-mix(in oklab, var(--color-stone) 60%, transparent);
  }

  .party__header {
    text-align: center;
    max-width: 38rem;
    margin: 0 auto clamp(2rem, 6vw, 3.5rem);
  }
  .party__title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0.4rem 0 0.85rem;
  }
  .party__lede {
    color: var(--color-muted);
    line-height: 1.7;
  }

  .party__group + .party__group {
    margin-top: clamp(2.5rem, 6vw, 4rem);
  }

  .party__group-title {
    text-align: center;
    font-size: clamp(2.5rem, 6vw, 3.75rem);
    color: var(--color-rose-deep);
    margin: 0 0 clamp(1.5rem, 3.5vw, 2rem);
  }

  .party__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 18rem), 1fr));
    gap: clamp(1rem, 2.5vw, 1.75rem);
  }

  .party__card {
    background: white;
    border: 1px solid var(--color-stone);
    padding: clamp(1.5rem, 3.5vw, 2rem);
    text-align: center;
    border-radius: 2px;
    transition: transform 320ms ease, box-shadow 320ms ease;
  }
  .party__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 48px -28px rgba(40, 30, 25, 0.3);
  }
  @media (hover: none) {
    .party__card:hover { transform: none; box-shadow: none; }
  }

  .party__avatar {
    width: 84px;
    height: 84px;
    margin: 0 auto 1rem;
    border-radius: 50%;
    background: linear-gradient(160deg, var(--color-rose) 0%, var(--color-rose-deep) 100%);
    color: white;
    display: grid;
    place-items: center;
    font-family: var(--font-serif);
    font-size: 1.65rem;
    letter-spacing: 0.04em;
  }
  .party__avatar--gent {
    background: linear-gradient(160deg, var(--color-ink-soft) 0%, var(--color-ink) 100%);
  }

  .party__name {
    font-family: var(--font-serif);
    font-size: clamp(1.25rem, 2.4vw, 1.5rem);
    margin: 0;
    color: var(--color-ink);
  }
  .party__role {
    font-family: var(--font-serif);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-size: 0.7rem;
    color: var(--color-rose-deep);
    margin: 0.35rem 0 1rem;
  }
  .party__bio {
    color: var(--color-ink-soft);
    line-height: 1.7;
    margin: 0;
  }
</style>
