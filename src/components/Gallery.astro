---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

const modules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/gallery/*.{jpg,jpeg,png}",
  { eager: true },
);

const photos = Object.entries(modules)
  .map(([path, mod]) => ({ path, src: mod.default }))
  .sort((a, b) => a.path.localeCompare(b.path));
---

<section id="gallery" class="section gallery">
  <div class="container-wide">
    <header class="gallery__header reveal">
      <p class="eyebrow">Gallery</p>
      <h2 class="gallery__title">Moments together</h2>
      <p class="gallery__lede">A few of our favorite memories so far. Tap any photo to enlarge.</p>
    </header>

    <ul class="gallery__grid">
      {photos.map((photo, i) => (
        <li class="gallery__item reveal" style={`--i: ${i}`}>
          <button
            class="gallery__btn"
            type="button"
            data-lightbox-trigger
            data-index={i}
            aria-label={`Open photo ${i + 1} of ${photos.length}`}
          >
            <Image
              src={photo.src}
              alt={`Alyssa & Nathan, photo ${i + 1}`}
              widths={[280, 480, 720, 960]}
              sizes="(max-width: 480px) 50vw, (max-width: 900px) 33vw, 22vw"
              loading="lazy"
            />
          </button>
        </li>
      ))}
    </ul>
  </div>

  <dialog class="lightbox" id="lightbox" aria-label="Photo viewer">
    <button class="lightbox__close" type="button" data-lightbox-close aria-label="Close photo viewer">
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
        <path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" />
      </svg>
    </button>
    <button class="lightbox__nav lightbox__nav--prev" type="button" data-lightbox-prev aria-label="Previous photo">
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
        <path d="M15 5l-7 7 7 7" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <button class="lightbox__nav lightbox__nav--next" type="button" data-lightbox-next aria-label="Next photo">
      <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
        <path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="1.6" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
    <figure class="lightbox__figure">
      <img id="lightbox-img" alt="" />
      <figcaption class="lightbox__caption" data-lightbox-caption></figcaption>
    </figure>
  </dialog>
</section>

<style>
  .gallery {
    background: var(--color-cream);
  }

  .gallery__header {
    text-align: center;
    max-width: 38rem;
    margin: 0 auto clamp(2rem, 5vw, 3rem);
  }
  .gallery__title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0.4rem 0 0.85rem;
  }
  .gallery__lede {
    color: var(--color-muted);
    line-height: 1.7;
  }

  .gallery__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    column-count: 4;
    column-gap: 0.75rem;
  }
  @media (max-width: 1100px) { .gallery__grid { column-count: 3; } }
  @media (max-width: 720px)  { .gallery__grid { column-count: 2; } }
  @media (max-width: 420px)  { .gallery__grid { column-count: 2; column-gap: 0.5rem; } }

  .gallery__item {
    break-inside: avoid;
    margin: 0 0 0.75rem;
    display: block;
  }
  @media (max-width: 420px) {
    .gallery__item { margin-bottom: 0.5rem; }
  }

  .gallery__btn {
    display: block;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    width: 100%;
    overflow: hidden;
    border-radius: 2px;
    line-height: 0;
  }
  .gallery__btn :global(img) {
    width: 100%;
    height: auto;
    transition: transform 600ms ease, filter 400ms ease;
  }
  .gallery__btn:hover :global(img),
  .gallery__btn:focus-visible :global(img) {
    transform: scale(1.04);
    filter: brightness(1.04);
  }

  /* Lightbox */
  .lightbox {
    border: 0;
    padding: 0;
    width: 100vw;
    height: 100svh;
    max-width: 100vw;
    max-height: 100svh;
    background: rgba(20, 16, 14, 0.94);
    color: var(--color-cream);
  }
  .lightbox::backdrop {
    background: rgba(20, 16, 14, 0.7);
  }
  .lightbox[open] {
    display: grid;
    place-items: center;
    inset: 0;
  }

  .lightbox__figure {
    margin: 0;
    padding: clamp(1rem, 4vw, 3rem);
    max-width: 100%;
    max-height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .lightbox__figure img {
    max-width: min(90vw, 1100px);
    max-height: 80svh;
    width: auto;
    height: auto;
    object-fit: contain;
    box-shadow: 0 30px 90px -30px rgba(0, 0, 0, 0.6);
  }
  .lightbox__caption {
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  .lightbox__close,
  .lightbox__nav {
    position: absolute;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: var(--color-cream);
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border-radius: 50%;
    cursor: pointer;
    transition: background 200ms ease, transform 200ms ease;
  }
  .lightbox__close:hover,
  .lightbox__nav:hover {
    background: rgba(255, 255, 255, 0.18);
    transform: scale(1.05);
  }
  .lightbox__close { top: 1rem; right: 1rem; }
  .lightbox__nav { top: 50%; transform: translateY(-50%); }
  .lightbox__nav--prev { left: 1rem; }
  .lightbox__nav--next { right: 1rem; }
  @media (max-width: 600px) {
    .lightbox__nav { width: 40px; height: 40px; }
    .lightbox__nav--prev { left: 0.5rem; }
    .lightbox__nav--next { right: 0.5rem; }
    .lightbox__close { top: 0.5rem; right: 0.5rem; }
  }
</style>

<script>
  const triggers = Array.from(
    document.querySelectorAll<HTMLButtonElement>("[data-lightbox-trigger]"),
  );
  const dialog = document.getElementById("lightbox") as HTMLDialogElement | null;
  const imgEl = document.getElementById("lightbox-img") as HTMLImageElement | null;
  const captionEl = document.querySelector<HTMLElement>("[data-lightbox-caption]");
  const closeBtn = document.querySelector<HTMLButtonElement>("[data-lightbox-close]");
  const prevBtn = document.querySelector<HTMLButtonElement>("[data-lightbox-prev]");
  const nextBtn = document.querySelector<HTMLButtonElement>("[data-lightbox-next]");

  if (dialog && imgEl && triggers.length) {
    let current = 0;

    const sources: { src: string; alt: string }[] = triggers.map((b) => {
      const im = b.querySelector("img") as HTMLImageElement;
      return { src: im.currentSrc || im.src, alt: im.alt };
    });

    const open = (i: number) => {
      current = (i + sources.length) % sources.length;
      const { src, alt } = sources[current];
      imgEl.src = src;
      imgEl.alt = alt;
      if (captionEl) captionEl.textContent = `${current + 1} / ${sources.length}`;
      if (!dialog.open) dialog.showModal();
    };

    triggers.forEach((b, i) => b.addEventListener("click", () => open(i)));
    closeBtn?.addEventListener("click", () => dialog.close());
    prevBtn?.addEventListener("click", () => open(current - 1));
    nextBtn?.addEventListener("click", () => open(current + 1));

    dialog.addEventListener("click", (e) => {
      const r = (e.target as HTMLElement).getBoundingClientRect?.();
      if (e.target === dialog && r) {
        const inDialog =
          e.clientX >= r.left &&
          e.clientX <= r.right &&
          e.clientY >= r.top &&
          e.clientY <= r.bottom;
        if (!inDialog) dialog.close();
      }
    });

    document.addEventListener("keydown", (e) => {
      if (!dialog.open) return;
      if (e.key === "ArrowRight") open(current + 1);
      else if (e.key === "ArrowLeft") open(current - 1);
    });

    // Touch swipe
    let touchStartX = 0;
    dialog.addEventListener("touchstart", (e) => {
      touchStartX = e.touches[0].clientX;
    }, { passive: true });
    dialog.addEventListener("touchend", (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      if (Math.abs(dx) > 40) open(current + (dx < 0 ? 1 : -1));
    });
  }
</script>
