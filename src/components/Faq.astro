---
const faqs = [
  {
    q: "When is the wedding?",
    a: "August 8, 2026.",
  },
  {
    q: "What time does the ceremony begin?",
    a: "4:00 PM, with cocktail hour and reception to follow.",
  },
  {
    q: "Where is the wedding?",
    a: "Stone Valley Estates in Huntingdon, PA. Both the ceremony and reception will be on-site.",
  },
  {
    q: "What should I wear?",
    a: "Black tie. Think sophisticated, polished, and elegant — gentlemen in tuxedos and ladies in formal floor-length attire. No jeans, please!",
  },
  {
    q: "Can I bring a plus one?",
    a: "Plus ones are listed by name on your invitation. If your invite is addressed to one, we kindly ask that you join us solo so we can celebrate with all of the people closest to us.",
  },
  {
    q: "Is the wedding indoors or outdoors?",
    a: "We're planning an outdoor ceremony with an indoor reception. We'll have a thoughtful weather backup ready in case the day calls for it.",
  },
  {
    q: "Are kids welcome?",
    a: "We love your little ones, but we've chosen to keep the celebration adults-only with a few exceptions for immediate family.",
  },
  {
    q: "Where should I stay?",
    a: "Hotel block details are coming soon — see the Travel & Stay section for AirBnB options in the meantime.",
  },
];
---

<section id="faq" class="section faq">
  <div class="container-narrow">
    <header class="faq__header reveal">
      <p class="eyebrow">Wedding FAQ</p>
      <h2 class="faq__title">Questions, answered</h2>
      <div class="divider" aria-hidden="true"><span class="script">~</span></div>
    </header>

    <ul class="faq__list">
      {faqs.map(({ q, a }, i) => (
        <li class="faq__item reveal">
          <details>
            <summary>
              <span class="faq__index">{String(i + 1).padStart(2, "0")}</span>
              <span class="faq__q">{q}</span>
              <span class="faq__icon" aria-hidden="true"></span>
            </summary>
            <div class="faq__a">
              <p>{a}</p>
            </div>
          </details>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .faq {
    background: var(--color-cream-50);
    border-block: 1px solid color-mix(in oklab, var(--color-stone) 60%, transparent);
  }
  .faq__header {
    text-align: center;
    margin-bottom: clamp(2rem, 5vw, 3.5rem);
  }
  .faq__title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0.4rem 0 1.25rem;
  }

  .faq__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  .faq__item {
    background: white;
    border: 1px solid var(--color-stone);
    border-radius: 4px;
    overflow: hidden;
  }

  details {
    width: 100%;
  }
  summary {
    list-style: none;
    cursor: pointer;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 1.1rem 1.25rem;
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    color: var(--color-ink);
    user-select: none;
  }
  summary::-webkit-details-marker { display: none; }

  .faq__index {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    color: var(--color-rose-deep);
    font-variant-numeric: tabular-nums;
  }
  .faq__q { font-weight: 500; }

  .faq__icon {
    width: 22px;
    height: 22px;
    position: relative;
    flex-shrink: 0;
  }
  .faq__icon::before,
  .faq__icon::after {
    content: "";
    position: absolute;
    inset: 0;
    margin: auto;
    background: var(--color-ink);
    transition: transform 280ms ease;
  }
  .faq__icon::before {
    width: 100%;
    height: 1.5px;
  }
  .faq__icon::after {
    width: 1.5px;
    height: 100%;
  }
  details[open] .faq__icon::after {
    transform: scaleY(0);
  }

  .faq__a {
    padding: 0 1.25rem 1.25rem calc(1.25rem + 2.5rem);
    color: var(--color-ink-soft);
    line-height: 1.7;
  }
  .faq__a p { margin: 0; }

  details[open] summary { color: var(--color-rose-deep); }

  @media (max-width: 600px) {
    summary { padding: 1rem; gap: 0.6rem; grid-template-columns: 1fr auto; }
    .faq__index { display: none; }
    .faq__a { padding: 0 1rem 1rem; }
  }
</style>
