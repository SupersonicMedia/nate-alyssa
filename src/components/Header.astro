---
const links = [
  { href: "#story", label: "Story" },
  { href: "#faq", label: "FAQ" },
  { href: "#travel", label: "Travel" },
  { href: "#party", label: "Bridal Party" },
  { href: "#registry", label: "Registry" },
  { href: "#gallery", label: "Gallery" },
  { href: "#rsvp", label: "RSVP" },
];
---

<header class="site-header" id="site-header">
  <div class="site-header__inner">
    <a href="#top" class="site-header__brand" aria-label="Alyssa & Nathan — home">
      <span class="site-header__monogram script" aria-hidden="true">A &amp; N</span>
      <span class="sr-only">Alyssa &amp; Nathan</span>
    </a>

    <button
      class="site-header__toggle"
      type="button"
      aria-controls="primary-menu"
      aria-expanded="false"
      aria-label="Open menu"
      data-menu-toggle
    >
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>

    <nav class="site-header__nav" id="primary-menu" aria-label="Primary">
      <ul>
        {links.map(({ href, label }, i) => (
          <li style={`--i: ${i}`}><a href={href} data-nav-link>{label}</a></li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in oklab, var(--color-cream) 92%, transparent);
    backdrop-filter: saturate(160%) blur(10px);
    -webkit-backdrop-filter: saturate(160%) blur(10px);
    border-bottom: 1px solid color-mix(in oklab, var(--color-stone) 60%, transparent);
  }

  .site-header__inner {
    max-width: 88rem;
    margin-inline: auto;
    padding: 0.75rem clamp(1rem, 4vw, 2rem);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    line-height: 1;
    color: var(--color-rose-deep);
    transition: color 220ms ease, transform 220ms ease;
  }
  .site-header__brand:hover { color: var(--color-rose); }

  .site-header__monogram {
    font-family: var(--font-script);
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    line-height: 0.9;
    letter-spacing: 0.02em;
    /* Slight optical lift to seat the script on the baseline cleanly */
    transform: translateY(2px);
    display: inline-block;
  }

  .site-header__nav {
    grid-column: 3;
    justify-self: end;
  }
  .site-header__nav ul {
    display: flex;
    align-items: center;
    gap: clamp(0.75rem, 2vw, 1.75rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .site-header__nav a {
    font-family: var(--font-serif);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-ink);
    text-decoration: none;
    padding-block: 0.4rem;
    position: relative;
  }
  .site-header__nav a::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 1px;
    background: var(--color-rose-deep);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 280ms ease;
  }
  .site-header__nav a:hover::after,
  .site-header__nav a:focus-visible::after,
  .site-header__nav a.is-active::after {
    transform: scaleX(1);
  }

  .site-header__toggle {
    display: none;
    background: none;
    border: 0;
    padding: 0.5rem;
    cursor: pointer;
    grid-column: 3;
    justify-self: end;
    width: 44px;
    height: 44px;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 5px;
  }
  .site-header__toggle .bar {
    display: block;
    width: 26px;
    height: 1.5px;
    background: var(--color-ink);
    transition: transform 250ms ease, opacity 200ms ease;
  }
  .site-header__toggle[aria-expanded="true"] .bar:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .site-header__toggle[aria-expanded="true"] .bar:nth-child(2) {
    opacity: 0;
  }
  .site-header__toggle[aria-expanded="true"] .bar:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  @media (max-width: 880px) {
    .site-header__toggle {
      display: inline-flex;
      /* Keep the toggle clickable above the open menu */
      position: relative;
      z-index: 70;
    }
    .site-header__brand {
      position: relative;
      z-index: 70;
    }

    .site-header__nav {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: 100svh;
      background: var(--color-cream);
      transform: translateY(-8px);
      opacity: 0;
      pointer-events: none;
      transition: opacity 280ms ease, transform 320ms ease;
      padding: clamp(5rem, 12vh, 7rem) clamp(1.5rem, 6vw, 3rem) clamp(2rem, 6vh, 3.5rem);
      overflow-y: auto;
      overscroll-behavior: contain;
      z-index: 60;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }
    .site-header__nav.is-open {
      opacity: 1;
      transform: none;
      pointer-events: auto;
    }

    /* Decorative monogram echoing the brand inside the open menu */
    .site-header__nav::before {
      content: "A & N";
      font-family: var(--font-script);
      font-size: clamp(4rem, 18vw, 7rem);
      color: var(--color-rose);
      opacity: 0.18;
      position: absolute;
      top: clamp(4rem, 14vh, 8rem);
      left: 50%;
      transform: translateX(-50%);
      pointer-events: none;
      line-height: 1;
    }

    .site-header__nav ul {
      flex-direction: column;
      align-items: center;
      gap: 0;
      width: 100%;
      max-width: 26rem;
      margin-block: auto;
    }
    .site-header__nav li {
      width: 100%;
      text-align: center;
      border-bottom: 1px solid color-mix(in oklab, var(--color-stone) 50%, transparent);
      opacity: 0;
      transform: translateY(8px);
    }
    .site-header__nav li:last-child { border-bottom: 0; }
    .site-header__nav.is-open li {
      animation: menuItemIn 420ms ease forwards;
      animation-delay: calc(80ms + var(--i, 0) * 55ms);
    }
    @keyframes menuItemIn {
      to { opacity: 1; transform: none; }
    }
    @media (prefers-reduced-motion: reduce) {
      .site-header__nav.is-open li { opacity: 1; transform: none; animation: none; }
    }
    .site-header__nav a {
      display: block;
      padding: 1.1rem 0.5rem;
      font-size: clamp(1.25rem, 4.5vw, 1.6rem);
      letter-spacing: 0.28em;
    }
    .site-header__nav a::after {
      left: 50%;
      right: auto;
      width: 40px;
      transform: translateX(-50%) scaleX(0);
      transform-origin: center;
    }
    .site-header__nav a:hover::after,
    .site-header__nav a:focus-visible::after,
    .site-header__nav a.is-active::after {
      transform: translateX(-50%) scaleX(1);
    }

    /* Subtle date footer at the bottom of the open menu */
    .site-header__nav::after {
      content: "08 . 08 . 26  ·  Stone Valley Estates";
      position: absolute;
      bottom: clamp(1.5rem, 5vh, 2.5rem);
      left: 50%;
      transform: translateX(-50%);
      font-family: var(--font-serif);
      font-size: 0.7rem;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--color-muted);
      white-space: nowrap;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLButtonElement>("[data-menu-toggle]");
  const menu = document.getElementById("primary-menu");

  const closeMenu = () => {
    if (!menu || !toggle) return;
    menu.classList.remove("is-open");
    toggle.setAttribute("aria-expanded", "false");
    toggle.setAttribute("aria-label", "Open menu");
    document.body.style.overflow = "";
  };

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isOpen = menu.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", String(isOpen));
      toggle.setAttribute("aria-label", isOpen ? "Close menu" : "Open menu");
      document.body.style.overflow = isOpen ? "hidden" : "";
    });

    menu.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", closeMenu);
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menu.classList.contains("is-open")) {
        closeMenu();
        toggle.focus();
      }
    });

    // Close if the viewport widens past the mobile breakpoint while open.
    const mq = window.matchMedia("(max-width: 880px)");
    mq.addEventListener("change", (e) => {
      if (!e.matches && menu.classList.contains("is-open")) closeMenu();
    });
  }

  // Active section highlighting based on scroll position
  const sections = Array.from(
    document.querySelectorAll<HTMLElement>(
      "#story, #faq, #travel, #party, #registry, #gallery, #rsvp",
    ),
  );
  const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]"));

  if ("IntersectionObserver" in window && sections.length) {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            navLinks.forEach((link) => {
              link.classList.toggle("is-active", link.getAttribute("href") === `#${id}`);
            });
          }
        });
      },
      { rootMargin: "-40% 0px -55% 0px" },
    );
    sections.forEach((s) => io.observe(s));
  }
</script>
